{
  "name": "openclaw-config-generator",
  "version": "1.5.0",
  "description": "OpenClaw plugin — Web UI & CLI to merge third-party API provider settings into openclaw.json",
  "license": "MIT",
  "author": "BaoxingZhang",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BaoxingZhang/openclaw-config-generator.git"
  },
  "homepage": "https://github.com/BaoxingZhang/openclaw-config-generator#readme",
  "bugs": {
    "url": "https://github.com/BaoxingZhang/openclaw-config-generator/issues"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "config",
    "api",
    "provider",
    "generator",
    "web-ui",
    "config-merge"
  ],
  "bin": {
    "openclaw-config-generator": "cli.js"
  },
  "engines": {
    "node": ">=22"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  },
  "files": [
    "index.ts",
    "cli.js",
    "public",
    "openclaw.plugin.json",
    "LICENSE",
    "assets"
  ]
}
